import apps::AppState
import apps::AppStatus
import jobs::Job

#[rust(type = "::serde_json::Value")]
opaque JsonValue

/// Health response.
record HealthResponse {
    /// Service status.
    status: string,
}

/// Error response body.
record ApiErrorResponse {
    /// Error details.
    error: ApiError,
}

/// API error details.
record ApiError {
    /// Machine-readable error code.
    code: string,
    /// Human-readable error message.
    message: string,
    /// Optional structured details.
    details?: JsonValue,
}

/// System summary shown by Rugix Admin.
record SystemInfoResponse {
    /// Active boot group, if known.
    active_boot_group?: string,
    /// Default boot group, if known.
    default_boot_group?: string,
    /// State-management status, if known.
    state_status?: string,
    /// Raw `rugix-ctrl system info --json` output.
    raw: JsonValue,
}

/// Output of the component consistency check.
record ComponentsCheckResponse {
    /// Component roots that were scanned.
    roots: [ComponentRoot],
    /// Components loaded from the scanned roots.
    components: [LoadedComponent],
    /// Whether the loaded component set is internally consistent.
    consistent: bool,
    /// Problems found while checking the component set.
    problems: [ComponentProblem],
}

/// Root directory scanned for component metadata.
record ComponentRoot {
    /// Kind of component source.
    kind: ComponentSourceKind,
    /// Root path.
    path: string,
    /// App name for app-owned roots.
    app?: string,
    /// Active app generation for app-owned roots.
    generation?: u64,
}

/// Component loaded from a source.
record LoadedComponent {
    /// Source from which the component was loaded.
    source: ComponentSource,
    /// Loaded component declaration.
    component: Component,
}

/// Source for a component declaration.
record ComponentSource {
    /// Kind of component source.
    kind: ComponentSourceKind,
    /// Source path or identifier.
    path: string,
    /// App name for app-owned sources.
    app?: string,
    /// Active app generation for app-owned sources.
    generation?: u64,
}

/// Kind of component source.
#[json(tagged = externally)]
variant ComponentSourceKind {
    /// Components installed as part of the system image.
    System,
    /// Persistent local or admin-provided components.
    Local,
    /// Runtime-generated components.
    Runtime,
    /// Component metadata owned by an active app generation.
    App,
    /// Component metadata declared by a bundle.
    Bundle,
    /// Component metadata synthesized by Rugix Ctrl.
    Synthetic,
}

/// Component declaration.
record Component {
    /// Component ID.
    id: string,
    /// Component version, if any.
    version?: string,
    /// Explicit capabilities provided by the component.
    provides: [Capability],
    /// Exclusive resource claims declared by the component.
    claims?: [Claim],
    /// Requirement selectors declared by the component.
    requires: [CapabilitySelector],
    /// Conflict selectors declared by the component.
    conflicts: [CapabilitySelector],
}

/// Exclusive resource claim.
record Claim {
    /// Claim ID.
    id: string,
}

/// Provided capability.
record Capability {
    /// Capability ID.
    id: string,
    /// Capability version, if any.
    version?: string,
    /// Capability value, if any.
    value?: string,
}

/// Capability selector used by requirements and conflicts.
record CapabilitySelector {
    /// Capability ID selected by the selector.
    id: string,
    /// Version requirement, if any.
    version?: string,
    /// Value matched by the selector, if any.
    value?: string,
}

/// Internal consistency problem in the component set.
#[json(tag = "kind")]
variant ComponentProblem {
    /// More than one component uses the same component ID.
    DuplicateComponent: DuplicateComponentProblem,
    /// More than one component claims the same exclusive resource.
    DuplicateClaim: DuplicateClaimProblem,
    /// A requirement selector was not satisfied.
    UnsatisfiedRequirement: UnsatisfiedRequirementProblem,
    /// A conflict selector matched a provided capability.
    Conflict: ComponentConflictProblem,
}

/// Duplicate component ID problem.
record DuplicateComponentProblem {
    /// Duplicate component ID.
    id: string,
    /// Sources declaring the duplicate component ID.
    sources: [ComponentSource],
}

/// Duplicate exclusive resource claim problem.
record DuplicateClaimProblem {
    /// Duplicate claim ID.
    id: string,
    /// Components declaring the duplicate claim.
    components: [ComponentRef],
}

/// Reference to a component and its source, if known.
record ComponentRef {
    /// Component ID.
    id: string,
    /// Source of the component, if known.
    source?: ComponentSource,
}

/// Unsatisfied requirement problem.
record UnsatisfiedRequirementProblem {
    /// Component declaring the requirement selector.
    component: ComponentRef,
    /// Requirement selector that was not satisfied.
    selector: CapabilitySelector,
}

/// Conflict problem.
record ComponentConflictProblem {
    /// Component declaring the conflict selector.
    component: ComponentRef,
    /// Conflict selector that matched.
    selector: CapabilitySelector,
    /// Component providing the conflicting capability.
    provider: ComponentRef,
    /// Capability matched by the conflict selector.
    capability: Capability,
}

/// List of installed apps.
record AppsListResponse {
    /// Apps sorted by name.
    apps: [AppSummary],
}

/// App summary.
record AppSummary {
    /// App name.
    name: string,
    /// Live workload status.
    status: AppStatus,
    /// Current generation, if any.
    generation?: u64,
    /// User-supplied metadata for the current generation.
    metadata?: JsonValue,
}

/// Detailed app information.
record AppInfoResponse {
    /// App name.
    name: string,
    /// Live workload status.
    status: AppStatus,
    /// Persisted app state.
    state: AppState,
    /// Installed generations.
    generations: [AppGeneration],
}

/// Generation information.
record AppGeneration {
    /// Generation number.
    number: u64,
    /// Creation timestamp.
    created_at: string,
    /// Whether the generation is complete.
    complete: bool,
    /// Whether the generation is currently active.
    active: bool,
    /// Timestamp of the last successful activation, if any.
    last_activated?: string,
    /// User-supplied generation metadata.
    metadata?: JsonValue,
}

/// Job response.
record JobResponse {
    /// Job snapshot.
    job: Job,
}

/// Job list response.
record JobsListResponse {
    /// Jobs, newest first.
    jobs: [Job],
}
