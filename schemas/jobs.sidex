/// Status of a Rugix Admin job.
#[json(tag = "status", rename_all = "kebab-case")]
variant JobStatus {
    /// The job has been created but has not started yet.
    Queued,
    /// The job is currently running.
    Running,
    /// The job completed successfully.
    Succeeded,
    /// The job failed.
    Failed: JobFailure,
}

/// Failure details for a job.
record JobFailure {
    /// Human-readable failure message.
    message: string,
    /// Process exit code, if the job failed because a process exited unsuccessfully.
    exit_code?: i32,
}

/// A privileged operation tracked by Rugix Admin.
record Job {
    /// Stable job id.
    id: string,
    /// Human-readable title.
    title: string,
    /// Machine-readable job kind.
    kind: string,
    /// Optional target, such as an app name.
    target?: string,
    /// Current job status.
    status: JobStatus,
    /// Creation timestamp.
    created_at: string,
    /// Last update timestamp.
    updated_at: string,
}
